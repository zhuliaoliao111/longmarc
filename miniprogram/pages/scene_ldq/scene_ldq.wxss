/* 页面容器样式 */
.container {
  position: relative;
  padding: 0px 0;
  overflow: hidden;
  height: 100vh;
  box-sizing: border-box;
  z-index: 1; /* 确保内容在背景图上方 */
}

/* 背景图片样式 */
.background-image {
  position: absolute;
  top: 0px;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* 置于内容下方 */
  opacity: 0.62;
  background-color: #f5f5f5; /* 图片加载前的背景色 */
}
.background-image1 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0; /* 置于内容下方 */
  opacity: 0.5;
  background-color: #f5f5f5; /* 图片加载前的背景色 */
}
.background-image2 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* 置于内容下方 */
  opacity: 0.5;
  background-color: #f5f5f5; /* 图片加载前的背景色 */
}
.content-wrapper {
  position: relative; /* 确保内容在背景图上方 */
  z-index: 1; /* 高于背景图的z-index: -1 */
}
/* 剧本容器样式 */
.script-container {
  width: 100%;
  height: 100%;
  margin: 0 auto;
  box-sizing: border-box;
  overflow: hidden;
}

/* 标题样式 */
.title {
  font-size: 22px;
  font-weight: bold;
  text-align: center;
  margin: 20px 0 10px; /* 调整上下间距 */
  padding-bottom: 10px;
  color: #c72525;
  border-bottom: 2px solid #e8e8e8;
}

.title1 {
  font-size: 22px;
  font-weight: bold;
  text-align: center;
  margin-top: 50px; /* 优化顶部间距 */
  margin-bottom: 20px; /* 取消负边距，避免空行 */
  color: #c72525;
  border-bottom: 2px solid #e8e8e8;
  padding: 0 12px; /* 增加左右内边距 */
}


/* 历史背景页文本容器样式 */
.background-content {
  font-size: 17px; 
  line-height: 2.2;
  margin: 20px 12px 0; /* 优化顶部间距，增加左右边距 */
  padding: 15px 12px;
  background-color: rgba(255, 255, 255, 0.65);
  border-radius: 10px; 
  text-align: justify; 
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); 
}

/* 历史背景页段落样式 */
.paragraph {
  display: block;
  margin-bottom: auto;
  white-space: pre-line;
  text-indent: 2em;  
  text-align: justify;
  margin-top: -35px; 
  padding-top: 0;
}

.paragraph:last-child {
  margin-bottom: 0;
}

/* 背景介绍文本样式（场景页） */
.background {
  font-size: 16px;
  line-height: 2.0;
  margin: 30px 0 20px 0;
  padding: 12px;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 8px;
}

.white-box {
  width: 100%;
  padding: 20px 16px; 
  box-sizing: border-box;
  background-color: rgb(247, 247, 240);
  border-radius: 10px;
  box-shadow: 0 3px 15px rgba(0, 0, 0, 0.1);
  position: absolute;
  top: 390px;
  bottom: 0;
  left: 0;
  right: 0;
  overflow-y: auto; /* 纵向溢出时显示滚动条，允许上下滚动 */
}

.scene1-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
.scene1-outer {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 剧情内容文本样式 */
.content {
  font-size: 17px;
  line-height: 1.8;
  margin: 5px 0 20px; /* 增加底部间距，与选项分离 */
  padding: 0 5px;
  text-align: justify;
}

.content1 {
  font-size: 18px;
  line-height: 2.5;
  margin: 50px 12px 30px; /* 优化顶部间距 */
  padding: 15px; /* 增加内边距 */
  text-align: justify;
  border-radius: 15px;
  background-color: rgba(255,255,255,0.7)
}

/* 选择项容器样式 */
.choices {
  display: flex;
  flex-direction: column;
  gap: 5px; /* 增大选项间距 */
  padding: 0 5px;
}

/* 单个选择项样式 */
.choice-item {
  display: flex;
  align-items: flex-start;
  padding: 8px 18px;
  border: 1px solid #e1e1e1;
  border-radius: 8px;
  background-color: rgba(246, 238, 238, 0.8);
  cursor: pointer;
  transition: all 0.3s;
}

/* 选择项 hover 效果 */
.choice-hover {
  background-color: #f0f7ff;
  border-color: #c9e0ff;
  transform: translateY(-2px);
}

/* 选项字母样式 */
.choice-letter {
  font-weight: bold;
  color: #c72525;
  min-width: 24px;
  margin-right: 8px;
  padding-top: 2px;
}

/* 选项文本样式 */
.choice-text {
  flex: 1;
  font-size: 16px;
  line-height: 1.6;
}

/* 结果提示样式 */
.result {
  padding: 15px 18px;
  margin: 20px 0;
  border-radius: 8px;
  border-left: 4px solid #ff0000;
  font-size: 16px;
  line-height: 1.7;
  background-color: rgba(255, 248, 248, 0.8);
}

/* 按钮组容器样式 */
.actions {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin: 0px 0 0px;
  padding: 0 5px;
}
.actions1 {
  display: flex;
  justify-content: center;
  margin-top: 10px; /* 增加顶部间距 */
  padding: 0 5px;
  color: #4d4b4b;
}

/* 返回按钮样式 */
.back-btn {
  padding: 10px 20px;
  border-radius: 6px;
  font-size: 16px;
  line-height: 1.4;
  background-color: #f5f5f5;
  color: #333;
  border: 1px solid #ddd;
  transition: all 0.2s;
  margin-top: -15px;
}

/* 下一步按钮样式 */
.next-btn {
  padding: 12px 24px;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 500;
  line-height: 1.4;
  background: linear-gradient(135deg, #c72525 0%, #a91409 100%);
  color: white;
  border: none;
  box-shadow: 0 4px 8px rgba(199, 37, 37, 0.3);
  transition: all 0.3s ease;
}

/* 结局页返回按钮样式 */
.return-btn {
  width: 100%;
  padding: 14px 0;
  margin: 40px 0 20px;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 500;
  line-height: 1.4;
  background: linear-gradient(135deg, #c72525 0%, #a91409 100%);
  margin-top: 50px;
  color: white;
  border: none;
  box-shadow: 0 4px 8px rgba(199, 37, 37, 0.3);
  transition: all 0.3s ease;
}

/* 按钮 hover 效果 */
.back-btn.btn-hover {
  background-color: #e9e9e9;
  transform: scale(1.02);
}

.next-btn.btn-hover,
.return-btn.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 2px 4px rgba(199, 37, 37, 0.4);
}

/* 打字光标样式 */
/* .cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background-color: #333;
  animation: blink 1s step-end infinite;
} */

@keyframes blink {
  from, to { opacity: 1; }
  50% { opacity: 0; }
}

/* 适配小屏设备 */
@media (max-width: 375px) {
  .background-content {
    margin: 30px 8px 0;
    font-size: 16px;
  }
  
  .title {
    font-size: 20px;
  }
  
  .choices {
    gap: 10px;
  }
  
  .white-box {
    top: 320px; /* 小屏调整位置 */
    overflow-y: auto;
    padding-bottom: 30px;
  }
}