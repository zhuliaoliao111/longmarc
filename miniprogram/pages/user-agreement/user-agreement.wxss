.container {
  width: 100%;
  height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 28rpx;
  background: none;
  border: none;
  color: #666666;
  padding: 10rpx 20rpx;
}

.close-btn::after {
  border: none;
}

.content {
  flex: 1;
  overflow-y: auto;
}

.text-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333333;
  text-align: left;
  white-space: pre-wrap;
}