.card-header {
  margin-bottom: 15px;
  margin: 0 20px 8px;
}

.artifact-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 2px;
}

.artifact-period {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 0;
}

.card-content {
  line-height: 1.5;
  margin: 0 20px 8px;
}

.artifact-material {
  font-size: 28rpx;
  color: #555;
  display: block;
  margin: -5px 0 6px;
}

.artifact-description {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 8px;
  line-height: 1.6;
}

.view-hint {
  background: #f8f9fa;
  padding: 15px;
  border-radius: 8px;
  border-left: 4px solid #ffc107;
}

.view-hint text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.5;
}

/* 独白容器 */
.expand-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 15rpx 0;
  color: #7a0000;
  font-size: 26rpx;
  cursor: pointer;
  margin-top: 10rpx;
}

.expand-text {
  margin-right: 8rpx;
}

.expand-icon {
  transition: transform 0.3s ease;
}

/* 可以添加点击反馈 */
.expand-trigger:active {
  opacity: 0.8;
}

.monologue-container {
  background: white;
  margin: 15px 15px 5px;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.monologue-header {
  margin-bottom: 20px;
}

.monologue-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.monologue-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.audio-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #e1d5b3;
  color: black;
  width: 80rpx;
  height: 80rpx;
  padding: 5rpx 0;
  border-radius: 12rpx;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}


.audio-btn:active {
  transform: translateY(1px);
  box-shadow: 0 1px 4px rgba(102, 126, 234, 0.3);
}

.audio-icon {
  width: 30rpx;
  height: 30rpx;
  margin-bottom: 2rpx;
}

.audio-text {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
  line-height: 1.2;
}

.monologue-content {
  line-height: 1.8;
  margin-bottom: 10px;
}

.monologue-text {
  font-size: 28rpx;
  color: #444;
  display: block;
  margin-bottom: 5px;
  text-indent: 2em;
  margin-top: 0 !important;
  padding-top: 0 !important; 
  line-height: 1.8;
}

.action-btn {
  background: #eef7ff;
  color: white;
  border: none;
  border-radius: 25px;
  padding: 12px 24px;
  font-size: 26rpx;
  box-shadow: 0 2px 10px rgba(102, 126, 234, 0.3);
}

.action-btn:active {
  transform: translateY(1px);
  box-shadow: 0 1px 5px rgba(102, 126, 234, 0.3);
}

/* 历史背景 */
.historical-context {
  margin: 15px;
}

.context-card {
  background: white;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15px;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.monologue-scroll {
  max-height: 300rpx;
  overflow-y: auto;
  padding-right: 8rpx;
  margin-top: 0; 
  padding-top: 0; 
}
