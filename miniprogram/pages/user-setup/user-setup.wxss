
.container {
  height: 100vh;
  overflow: hidden;
  background-color: #f8f9fa;
  position: relative;
  padding: 0 !important; 
  margin: 0 !important; 
}


.header-background {
  width: 100%;
  height: 650rpx;
  position: relative;
  overflow: hidden;
  margin-top: -200rpx; 
 
}

.background-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}


.content-card {
  background-color: #FDFBF6; 
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -250rpx;
  padding: 60rpx 40rpx 40rpx;
  height: calc(100vh - 200rpx);
  overflow-y: auto;
  box-shadow: 0 -8rpx 32rpx rgba(139, 124, 99, 0.15); 
  position: relative;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx; 
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

/* 头像设置区域 */
.avatar-section {
  background-color: #F8F7F2; 
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 60rpx;
  margin: 0 auto 20rpx;
  background-color: #fff;
  border: 2rpx solid #E5DCC8; 
  box-shadow: 0 4rpx 12rpx rgba(139, 124, 99, 0.1); 
}

.avatar {
  display: block;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.avatar-desc {
  font-size: 24rpx;
  color: #999;
}

/* 昵称设置区域 */
.nickname-section {
  background-color: #F8F7F2; 
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  text-align: center; 
}

.row {
  border: 1rpx solid #E5DCC8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  height: 100rpx;
  padding: 0 20rpx;
  background-color: #fff;
  justify-content: center; 
}

.text1 {
  flex: none; 
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx; 
}

.weui-input {
  flex: none;
  font-size: 28rpx;
  color: #333;
  border: none;
  text-align: center;
  width: 300rpx;
}

/* 按钮区域 */
.button-section {
  display: flex;
  flex-direction: row; 
  gap: 20rpx;
  margin-top: 300rpx; 
  justify-content: center;
}

.submit-btn {
  background-color: #8B4513; 
  color: white;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
  flex: 1;
  max-width: 300rpx;
}

.skip-btn {
  background-color: #F8F7F2;
  color: #8B7428; 
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  border: 1rpx solid #E5DCC8; 
  flex: 1; 
  max-width: 300rpx; 
}
