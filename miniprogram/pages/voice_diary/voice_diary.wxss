.container {
  height: 100vh;
  background: #FFFFFF;
  padding: 40rpx 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.background-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50vh;
  overflow: hidden;
  z-index: 0;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.gradient-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.5) 40%, rgba(255,255,255,1) 100%);
  pointer-events: none;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.title-container {
  position: relative;
  display: inline-block;
  margin-bottom: 30rpx;
}

.plum-bg {
  width: 420rpx;
  height: 320rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0.6;
  z-index: 0;
}

.title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 64rpx;
  font-weight: 900;
  color: #3d2817;
  padding: 35rpx 75rpx;
  letter-spacing: 12rpx;
  font-family: "STXingkai", "Xingkai SC", "STKaiti", "KaiTi", "SimKai", serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.8);
  transform: skew(-2deg, 0deg);
}

.disclaimer {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-top: 10rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.swiper-container {
  width: 100%;
  flex: 1;
  padding: 40rpx 0 150rpx 0;
  overflow: visible;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.diary-swiper {
  width: 100%;
  height: 100%;
  overflow: visible;
}


swiper-item {
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}


.diary-card {
  width: 360rpx;
  height: 540rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.15);
  overflow: hidden;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  transform: scale(0.8) rotateY(8deg);
  opacity: 0.7;
  margin: 0 auto;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}


.diary-card:not(.active) {
  transform: scale(0.8) rotateY(12deg);
  opacity: 0.75;
}


.diary-card.active {
  width: 400rpx;
  height: 600rpx;
  transform: scale(1.0) rotateY(0deg);
  opacity: 1;
  box-shadow: 
    0 35rpx 80rpx rgba(139, 69, 19, 0.3),
    0 15rpx 35rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  z-index: 10;
  border: 3rpx solid rgba(139, 69, 19, 0.3);
}


.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  filter: brightness(0.9) contrast(1.05);
}

.diary-card.active .card-image {
  filter: brightness(1) contrast(1.15);
}


.diary-card:not(.active)::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(139, 69, 19, 0.08);
  border-radius: 32rpx;
  z-index: -1;
}

.diary-card.active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(139, 69, 19, 0.05);
  border-radius: 32rpx;
  z-index: -1;
}


.diary-card.active::after {
  display: none;
}


.diary-swiper .wx-swiper-dot {
  width: 18rpx !important;
  height: 18rpx !important;
  margin: 0 10rpx !important;
  background: rgba(139, 69, 19, 0.3) !important;
  border-radius: 50% !important;
  transition: all 0.4s ease !important;
  border: 2rpx solid rgba(139, 69, 19, 0.2) !important;
}

.diary-swiper .wx-swiper-dot-active {
  background: #8B4513 !important;
  transform: scale(1.2) !important;
  border-color: rgba(139, 69, 19, 0.5) !important;
}