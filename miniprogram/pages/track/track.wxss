.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
}

/* 模式切换标签 */
.mode-tabs {
  display: flex;
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  color: #B22222; 
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #B22222; 
  background: white;
  font-weight: bold;
}

.record-mode {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0; 
  position: relative;
}

.map-container {
  width: 100%;
  height: 100%;
  border-radius: 0;
  overflow: hidden;
  margin: 0;
}

/* 距离显示区域 */
.distance-section {
  position: absolute;
  bottom: 350rpx;
  left: 20rpx; 
  display: flex;
  align-items: baseline;
  justify-content: flex-start; 
  padding: 20rpx 0;
  background: transparent;
  z-index: 10;
}

/* 运动效率详细说明样式 */
.efficiency-detail-tip {
  position: absolute;
  bottom: 500rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10rpx);
  z-index: 15;
  border: 2rpx solid #ff6b6b;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-hint {
  font-size: 24rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.detail-items {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.detail-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin: 0 8rpx;
  position: relative;
}

.detail-item.highlight {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: white;
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.detail-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.detail-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.detail-item.highlight .detail-label {
  color: white;
}

.detail-desc {
  font-size: 24rpx;
  color: #666;
}

.detail-item.highlight .detail-desc {
  color: rgba(255, 255, 255, 0.9);
}

.efficiency-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #ff4757;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: bold;
}

.detail-footer {
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 12rpx;
}

.detail-tip {
  font-size: 24rpx;
  color: #ff6b6b;
  line-height: 1.4;
}


.distance-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #000000; 
  line-height: 1;
}

.distance-unit {
  font-size: 32rpx;
  color: #333333;
  margin-left: 10rpx;
  font-weight: normal;
}

/* 透明统计框 */
.stats-container {
  position: absolute;
  bottom: 20rpx; 
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 30rpx 20rpx 40rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
  font-weight: normal;
}

.controls {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 0 0;
  background-color: transparent;
  margin-top: 20rpx;
}

.control-btn {
  background-color: #B22222;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 18rpx 80rpx; 
  font-size: 26rpx; 
  font-weight: bold;
  margin: 0 15rpx; 
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
}



/* Styles from map.wxss */
/* Add toggle button in controls or separately */

/* From map.wxss */
.stats-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #f5f5f5;
  display: flex;
  justify-content: space-around;
  padding: 16px 0;
  border-top: 1px solid #e0e0e0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  color: #999;
}

.progress-bar {
  background-color: rgba(245, 245, 245, 0.9);
  padding: 20px 16px;
  margin-bottom: 8px;
  border-radius: 8px;
}

.progress-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-track {
  width: 100%;
  height: 16px;
  background: linear-gradient(to right, #ffa500, #ff2d55);
  border-radius: 8px;
  position: relative;
  margin-bottom: 16px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #ffa500, #ff2d55);
  border-radius: 8px;
  transition: width 0.3s ease;
}

.user-avatar {
  position: absolute;
  top: -250px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 3px solid #fff;
  transform: translateX(-50%);
  transition: left 0.3s ease;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.destination-labels {
  display: flex;
  justify-content: space-between;
  width: 100%;
}

.destination-label {
  background-color: #e0e0e0;
}

/* 历史轨迹记录样式 */
.history-section {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  flex: 1;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.trajectory-list {
  flex: 1;
  max-height: 60vh;
}

.trajectory-card {
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 50rpx; 
}

.trajectory-card:last-child {
  margin-bottom: 0; 
}

/* 运动总距离统计 */
.total-exercise-section {
  margin: 30rpx 20rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e5e5;
  flex-shrink: 0;
  margin-top: 48vh;
  margin-left: 80rpx;
  box-shadow: 0 0 0 3rpx #ffffff, 0 0 0 5rpx #e5e5e5;
}

.exercise-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.total-exercise-value {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-left: 30rpx;
}

.total-exercise-title {
  font-size: 28rpx;
  color: #000000;
  font-weight: normal;
  margin-bottom: 15rpx;
}

.total-exercise-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.distance-number {
  font-size: 64rpx;
  color: #000000;
  font-weight: bold;
}

.distance-unit {
  font-size: 32rpx;
  color: #000000;
  font-weight: normal;
}

.trajectory-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.trajectory-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  z-index: 1;
}

.trajectory-info {
  flex: 1;
  position: relative;
  z-index: 2;
}

.trajectory-date {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.trajectory-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 120rpx;
  margin-top: -50rpx;
}

.trajectory-stats .stat {
  font-size: 24rpx;
  color: #CD5C5C;
}

.trajectory-canvas-container {
  width: 200rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 10rpx;
  border: 1rpx solid #CD5C5C;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

.trajectory-canvas {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  display: block;
  margin: 0; 
}


.canvas-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(240, 240, 240, 0.9);
  border-radius: 8rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.debug-info {
  position: absolute;
  top: 5rpx;
  left: 5rpx;
  right: 5rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 4rpx;
  padding: 4rpx;
  z-index: 10;
}

.debug-text {
  font-size: 18rpx;
  color: #fff;
  display: block;
  line-height: 1.2;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.8);
}

.trajectory-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.trajectory-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: #999;
  font-size: 24rpx;
}

/* 空状态样式 */
.empty-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-content {
  text-align: center;
}

.empty-text {
  font-size: 36rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.start-record-btn {
  background: linear-gradient(135deg, #af3d3d, #a04545);
  color: white;
  border: none;
  border-radius: 44rpx;
  padding: 10rpx 30rpx;
  font-size: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}
