page {
  background: #fffef9;
  transition: background-color 0.3s ease;
}

page.dark-mode {
  background: #1a1a1a;
}

.reader-container {
  width: 100vw;
  height: 100vh;
  background: #fffef9;
  position: relative;
  overflow: hidden;
  transition: background-color 0.3s ease;
}

.reader-container.dark-mode {
  background: #1a1a1a;
}

/* 自定义导航栏占位 */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fffef9;
  z-index: 99;
  transition: background-color 0.3s ease;
}

.dark-mode .custom-nav-bar {
  background: #1a1a1a;
}

/* 书页包装器 */
.book-page-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
  perspective: 2500rpx; /* 增强3D透视效果 */
  perspective-origin: 50% 50%;
  overflow: hidden;
}

/* 书页样式 */
.book-page {
  width: 100%;
  height: 100%;
  background: #fffef9;
  position: absolute;
  top: 0;
  left: 0;
  transform-style: preserve-3d;
  /* 简化纸张纹理 */
  background-image: 
    radial-gradient(
      ellipse at 30% 40%,
      rgba(250, 247, 230, 0.15) 0%,
      transparent 50%
    ),
    radial-gradient(
      ellipse at 70% 60%,
      rgba(245, 240, 215, 0.1) 0%,
      transparent 50%
    );
  transition: background-color 0.3s ease;
}

/* 夜间模式书页 */
.dark-mode .book-page {
  background: #1a1a1a;
  background-image: 
    radial-gradient(
      ellipse at 30% 40%,
      rgba(60, 50, 30, 0.15) 0%,
      transparent 50%
    ),
    radial-gradient(
      ellipse at 70% 60%,
      rgba(50, 40, 20, 0.1) 0%,
      transparent 50%
    );
}

/* 下一页预览（底层） */
.next-page-preview {
  z-index: 0;
}

.current-page {
  z-index: 1;
  will-change: transform;
  transition: none;
  transform-origin: left center; /* 以左边缘为轴 */
}

.page-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 25rpx;
  margin-bottom: 25rpx;
  border-bottom: 1rpx solid rgba(139, 69, 19, 0.2);
}

.date {
  font-weight: 500;
  color: #8B4513;
  transition: color 0.3s ease;
}

.dark-mode .date {
  color: #d4a574;
}

.page-content {
  flex: 1;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
}

.diary-text {
  color: #2c2c2c;
  text-indent: 2em;
  word-break: break-word;
  letter-spacing: 1rpx;
  transition: color 0.3s ease;
  padding-right: 10rpx;
}

.dark-mode .diary-text {
  color: #f5e6d3;
}

.page-footer {
  padding: 20rpx 0;
  text-align: center;
}

.page-number {
  color: #8B4513;
  opacity: 0.5;
  transition: color 0.3s ease;
}

.dark-mode .page-number {
  color: #d4a574;
  opacity: 0.6;
}

/* 翻页层 */
.flip-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  z-index: 10;
  will-change: transform;
  backface-visibility: visible;
  transform-origin: left center;
}

.flip-page-front,
.flip-page-back {
  position: absolute;
  width: 100%;
  height: 100%;
  background: #fffef9;
  backface-visibility: hidden;
  /* 简化纸张纹理 */
  background-image: 
    radial-gradient(
      ellipse at 30% 40%,
      rgba(250, 247, 230, 0.15) 0%,
      transparent 50%
    );
  transition: background-color 0.3s ease;
}

/* 夜间模式翻页层 */
.dark-mode .flip-page-front,
.dark-mode .flip-page-back {
  background: #1a1a1a;
  background-image: 
    radial-gradient(
      ellipse at 30% 40%,
      rgba(60, 50, 30, 0.15) 0%,
      transparent 50%
    );
}

.flip-page-front {
  z-index: 2;
  transform: rotateY(0deg);
  left: 0;
}

.flip-page-back {
  transform: rotateY(180deg);
  z-index: 1;
  left: 0;
}

/* 仿真翻页动画 - 向右翻（下一页）- 波浪效果 */
.flip-page.flip-right {
  animation: flipToRight 1s cubic-bezier(0.23, 1, 0.32, 1);
  transform-origin: left center;
}

@keyframes flipToRight {
  0% {
    transform: perspective(2500rpx) rotateY(0deg) translateZ(0rpx) scaleX(1);
  }
  15% {
    transform: perspective(2500rpx) rotateY(-27deg) translateZ(15rpx) scaleX(1.01) scaleY(0.995);
  }
  30% {
    transform: perspective(2500rpx) rotateY(-54deg) translateZ(25rpx) scaleX(1.02) scaleY(0.99);
  }
  50% {
    transform: perspective(2500rpx) rotateY(-90deg) translateZ(35rpx) scaleX(1.04) scaleY(0.985);
  }
  70% {
    transform: perspective(2500rpx) rotateY(-126deg) translateZ(25rpx) scaleX(1.02) scaleY(0.99);
  }
  85% {
    transform: perspective(2500rpx) rotateY(-153deg) translateZ(15rpx) scaleX(1.01) scaleY(0.995);
  }
  100% {
    transform: perspective(2500rpx) rotateY(-180deg) translateZ(0rpx) scaleX(1);
  }
}

/* 仿真翻页动画 - 向左翻（上一页）- 波浪效果 */
.flip-page.flip-left {
  animation: flipToLeft 1s cubic-bezier(0.23, 1, 0.32, 1);
  transform-origin: left center;
}

@keyframes flipToLeft {
  0% {
    transform: perspective(2500rpx) rotateY(-180deg) translateZ(0rpx) scaleX(1);
  }
  15% {
    transform: perspective(2500rpx) rotateY(-153deg) translateZ(15rpx) scaleX(1.01) scaleY(0.995);
  }
  30% {
    transform: perspective(2500rpx) rotateY(-126deg) translateZ(25rpx) scaleX(1.02) scaleY(0.99);
  }
  50% {
    transform: perspective(2500rpx) rotateY(-90deg) translateZ(35rpx) scaleX(1.04) scaleY(0.985);
  }
  70% {
    transform: perspective(2500rpx) rotateY(-54deg) translateZ(25rpx) scaleX(1.02) scaleY(0.99);
  }
  85% {
    transform: perspective(2500rpx) rotateY(-27deg) translateZ(15rpx) scaleX(1.01) scaleY(0.995);
  }
  100% {
    transform: perspective(2500rpx) rotateY(0deg) translateZ(0rpx) scaleX(1);
  }
}

/* 滑动翻页 */
.book-page.page-slide-left {
  animation: slideOutLeft 0.3s ease;
}

.book-page.page-slide-right {
  animation: slideOutRight 0.3s ease;
}

@keyframes slideOutLeft {
  from { transform: translateX(0); }
  to { transform: translateX(-100%); }
}

@keyframes slideOutRight {
  from { transform: translateX(0); }
  to { transform: translateX(100%); }
}

/* 覆盖翻页 */
.book-page.page-fade {
  animation: fadeInOut 0.4s ease;
}

@keyframes fadeInOut {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* 顶部导航 */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fffef9;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  z-index: 100;
  transform: translateY(-100%);
  transition: transform 0.3s ease, background-color 0.3s ease;
}

.dark-mode .top-nav {
  background: #1a1a1a;
}

.top-nav.show {
  transform: translateY(0);
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nav-icon {
  font-size: 40rpx;
  color: #8B4513;
  font-weight: bold;
  transition: color 0.3s ease;
}

.dark-mode .nav-icon {
  color: #d4a574;
}

.nav-text {
  font-size: 28rpx;
  color: #8B4513;
  transition: color 0.3s ease;
}

.dark-mode .nav-text {
  color: #d4a574;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  color: #8B4513;
  font-weight: 500;
  transition: color 0.3s ease;
}

.dark-mode .nav-title {
  color: #d4a574;
}

.nav-right {
  width: 180rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

/* 主题切换按钮 */
.theme-icon-btn {
  width: 48rpx;
  height: 48rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: rgba(139, 69, 19, 0.1);
  transition: all 0.3s ease;
}

.theme-icon-btn:active {
  background: rgba(139, 69, 19, 0.2);
  transform: scale(0.95);
}

/* 语音播放按钮 - 顶部导航右侧 */
.voice-icon-btn {
  width: 48rpx;
  height: 48rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: rgba(139, 69, 19, 0.1);
  transition: all 0.3s ease;
}

.voice-icon-btn.playing {
  background: rgba(220, 20, 60, 0.2);
  animation: voicePulse 1.5s infinite;
}

@keyframes voicePulse {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.9;
  }
  50% { 
    transform: scale(1.1); 
    opacity: 1;
  }
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: #fffef9;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease, background-color 0.3s ease;
}

.dark-mode .bottom-nav {
  background: #1a1a1a;
}

.bottom-nav.show {
  transform: translateY(0);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 0 30rpx;
}

/* 底部导航图标样式 */
.nav-icon-img {
  width: 56rpx;
  height: 56rpx;
  padding: 10rpx;
  border-radius: 50%;
  background: rgba(139, 69, 19, 0.1);
  transition: all 0.3s ease;
}

.nav-item:active .nav-icon-img {
  background: rgba(139, 69, 19, 0.2);
  transform: scale(0.95);
}

.nav-item .nav-icon {
  font-size: 36rpx;
}

.nav-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  transition: color 0.3s ease;
}

.dark-mode .nav-label {
  color: #999;
}

.nav-progress {
  flex: 1;
  padding: 0 20rpx;
}

/* 设置面板 */
.settings-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
}

.settings-panel.show {
  display: block;
}

.settings-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.settings-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #2d2d2d;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 30rpx;
  max-height: 75vh;
  animation: slideUp 0.3s ease;
  transition: background-color 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.settings-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 500;
}

.settings-close {
  font-size: 40rpx;
  color: #888;
  font-weight: 300;
}

.setting-item {
  margin-bottom: 45rpx;
}

.setting-label {
  display: block;
  font-size: 28rpx;
  color: #bbb;
  margin-bottom: 20rpx;
}

.setting-slider {
  width: 100%;
}

.setting-double-slider {
  display: flex;
  gap: 30rpx;
}

.slider-item {
  flex: 1;
}

.slider-label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 15rpx;
  text-align: center;
}

.setting-slider-small {
  width: 100%;
}

.setting-options {
  display: flex;
  gap: 15rpx;
}

.option-btn {
  flex: 1;
  height: 70rpx;
  background: #3d3d3d;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.option-btn.active {
  background: linear-gradient(135deg, #d4a574, #c19563);
  color: #2d2d2d;
  font-weight: 500;
}

.font-options {
  white-space: nowrap;
  height: 80rpx;
}

.font-option {
  display: inline-block;
  padding: 18rpx 28rpx;
  background: #3d3d3d;
  border-radius: 12rpx;
  margin-right: 15rpx;
  color: #999;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.font-option.active {
  background: linear-gradient(135deg, #d4a574, #c19563);
  color: #2d2d2d;
  font-weight: 500;
}

/* 目录面板 */
.catalog-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
}

.catalog-panel.show {
  display: block;
}

.catalog-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.catalog-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #2d2d2d;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 0 0 0;
  max-height: 80vh;
  animation: slideUp 0.3s ease;
  display: flex;
  flex-direction: column;
  transition: background-color 0.3s ease;
}

.catalog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 30rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.catalog-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 500;
}

.catalog-close {
  font-size: 40rpx;
  color: #888;
  font-weight: 300;
}

.catalog-list {
  flex: 1;
  padding: 20rpx 0;
  max-height: calc(80vh - 120rpx);
}

.catalog-item {
  display: flex;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: background 0.2s ease;
}

.catalog-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.catalog-item.active {
  background: rgba(212, 165, 116, 0.15);
  border-left: 4rpx solid #d4a574;
}

.catalog-item-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(139, 69, 19, 0.3);
  color: #d4a574;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.catalog-item.active .catalog-item-number {
  background: #d4a574;
  color: #2d2d2d;
  font-weight: 600;
}

.catalog-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.catalog-item-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.catalog-item.active .catalog-item-title {
  color: #d4a574;
}

.catalog-item-preview {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}