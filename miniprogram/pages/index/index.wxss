/* 标签页区域 */
.tab-section {
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 10rpx; 
  margin-bottom: 2rpx;
}

.main-tabs {
  display: flex;
  margin-bottom: 30rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color:  #7a0000;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 3rpx;
  background:  #7a0000;
  border-radius: 2rpx;
}

/* 内容卡片区域 */
.content-section {
  padding: 0 20rpx 40rpx;
}

.content-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.content-card {
  background: #7a0000;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  border: 2rpx solid #eee; 
  height: auto;
}

.content-image-container {
  width: 100%;
  padding-top: 54.88%; 
  position: relative;
  overflow: hidden;
}

.content-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 200%;
  object-fit: cover;
}

.content-info {
  padding: 15rpx 25rpx;
}

.content-title {
  font-size: 25rpx;
  font-weight: bold;
  color: #f1e7d7;
  text-align: center;
  white-space: nowrap;
  margin-bottom: 0;
  display: block;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .content-grid {
    grid-template-columns: 1fr;
  }

  .category-section {
    flex-wrap: wrap;
    gap: 20rpx;
  }

  .category-item {
    flex: 0 0 20%;
  }
} 