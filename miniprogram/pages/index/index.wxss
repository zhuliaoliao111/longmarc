page {
  width: 100%;
  height: 100vh; 
  overflow: hidden;
}

.container {
  position: relative; 
  min-height: 100vh;
  margin: 0;
}
.bg-image {
  position: absolute; 
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; 
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  color: white;
}

.header-left {
  flex: 5;
}

.logo {
  display: flex;
  flex-direction: column;
  white-space: normal;
}

.logo-text {
  font-size: 50rpx;
  font-weight: bold;
  color: #f6b662;
  margin-left: 7rpx;
  font-family: "STXingkai", "华文行楷", serif;
}

.logo-en {
  font-size: 25rpx;
  color:#f6b662;
  font-family: "Arial", "Helvetica", sans-serif; 
  margin-top: 4rpx;
  margin-left: 15rpx;
  white-space: normal;
  line-height: 1.2;
  display: block; 
  font-weight: bold;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-container {
  width: 90rpx;
  height:90rpx;
  border-radius: 45rpx; 
  background: rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.avatar-container:active {
  transform: scale(0.95);
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 29rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}


.login-placeholder {
  width: 100%;
  height: 100%;
  background: #f1e7d7;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-image{
    object-fit: contain;
    width: 70rpx; 
    height: 70rpx; 
}

/*轮播图*/
.banner-section {
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.banner-swiper {
  height: 350rpx;
}

.banner-swiper .wx-swiper-dot {
  background-color: rgba(255, 255, 255, 0.5);
  width: 12rpx;
  height: 12rpx;
  margin: 0 6rpx;
}


.banner-swiper .wx-swiper-dot.wx-swiper-dot-active {
  background-color: #f1e7d7; 
  width: 30rpx;
  border-radius: 6rpx; 
}

.banner-image-container {
  width: 100%;
  height: 100%; 
  height: 350rpx;
}

.banner-item {
  position: relative;
  height: 100%;
  height: 350rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 40rpx 30rpx 30rpx;
  color: #f1e7d7;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.banner-tagline {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 分类图标区域 */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
  margin: 0 20rpx;
  border-radius: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.category-icon {
  width: 80rpx;
  height:80rpx;
  border-radius: 50%;
  background-color: #7a0000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.icon-image {
  object-fit: contain;
  width: 80rpx; 
  height: 80rpx; 
}

.category-icon1 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #7a0000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}
.category-icon1 image {
  width: 60rpx; 
  height: 60rpx; 
}

.category-text {
  font-size: 24rpx;
  color: #7a0000;
  text-align: center;
}

/* 地图区域 */
.card-section {
  margin: 20rpx;
}

.one-card {
  position: relative;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(84, 16, 2, 0.3);
  height: 170rpx;
}

.card-bg {
  position: absolute;
  left: 0; 
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.card-bg-image {
  width: 100%;
  height: 100%;
  display: block;
}

.card-right {
  position: relative;
  z-index: 2;
  text-align: right; 
  padding-top: 15rpx;
}

.card-title {
  font-size: 55rpx;
  font-weight: bold;
  color: #7a0000;
  font-family: "STXinwei", "华文新魏", serif;
  margin-bottom: 12rpx;
  text-align: right;
  margin-top: -10rpx;
}

.card-text {
  color: rgba(122, 0, 0, 0.7);
  font-size: 35rpx; 
  font-family: "STXinwei", "华文新魏", serif;
  text-align: right;
}

