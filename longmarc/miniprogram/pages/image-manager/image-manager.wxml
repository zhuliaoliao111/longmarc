<!--pages/image-manager/image-manager.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <view class="title">图片资源管理</view>
    <view class="subtitle">将本地图片上传到云存储，减少小程序包体积</view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stat-item">
      <view class="stat-value">{{totalImages}}</view>
      <view class="stat-label">总图片数</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{uploadedImages}}</view>
      <view class="stat-label">已上传</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{cachedImages}}</view>
      <view class="stat-label">已缓存</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions-section">
    <button class="action-btn test-btn" bindtap="testCloudFunction">
      <text class="btn-text">🧪 测试云函数</text>
    </button>

    <button class="action-btn upload-btn" bindtap="uploadAllImages">
      <text class="btn-text">📤 上传所有图片</text>
    </button>

    <button class="action-btn refresh-btn" bindtap="refreshCache">
      <text class="btn-text">🔄 刷新缓存</text>
    </button>

    <button class="action-btn clear-btn" bindtap="clearCache">
      <text class="btn-text">🗑️ 清除缓存</text>
    </button>
  </view>

  <!-- 图片列表 -->
  <view class="images-section">
    <view class="section-title">图片列表</view>
    <view class="images-grid">
      <view class="image-item" wx:for="{{imageList}}" wx:key="name">
        <image class="image-preview" src="{{item.url}}" mode="aspectFill" binderror="onImageError"></image>
        <view class="image-info">
          <view class="image-name">{{item.name}}</view>
          <view class="image-status {{item.statusClass}}">{{item.statusText}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 说明文本 -->
  <view class="info-section">
    <view class="info-title">📋 使用说明</view>
    <view class="info-list">
      <view class="info-item">• 点击"上传所有图片"按钮，将本地images文件夹中的所有图片上传到云存储</view>
      <view class="info-item">• 上传完成后，小程序会自动使用云存储的图片URL，减少包体积</view>
      <view class="info-item">• 图片URL会被缓存，提升加载速度</view>
      <view class="info-item">• 支持37张图片资源的管理</view>
    </view>
  </view>
</view>
