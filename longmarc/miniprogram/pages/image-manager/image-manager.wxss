/* pages/image-manager/image-manager.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.stats-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #e8241d;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.actions-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.test-btn {
  background: linear-gradient(135deg, #4caf50, #81c784);
  color: white;
}

.upload-btn {
  background: linear-gradient(135deg, #e8241d, #ff5722);
  color: white;
}

.refresh-btn {
  background: linear-gradient(135deg, #2196f3, #21cbf3);
  color: white;
}

.clear-btn {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
  color: white;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 500;
}

.images-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.image-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e9ecef;
}

.image-preview {
  width: 100%;
  height: 120rpx;
  background: #f0f0f0;
}

.image-info {
  padding: 16rpx;
}

.image-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  word-break: break-all;
  line-height: 1.3;
}

.image-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  display: inline-block;
  font-weight: 500;
}

.image-status.success {
  background: #e8f5e8;
  color: #2e7d32;
}

.image-status.failed {
  background: #ffebee;
  color: #c62828;
}

.image-status.loading {
  background: #fff3e0;
  color: #ef6c00;
}

.image-status.cached {
  background: #e3f2fd;
  color: #1565c0;
}

.info-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  padding-left: 20rpx;
  position: relative;
}

.info-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 6rpx;
  height: 6rpx;
  background: #e8241d;
  border-radius: 50%;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .images-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stats-section {
    flex-direction: column;
    gap: 20rpx;
  }

  .stat-item {
    margin-bottom: 0;
  }
}
