<!-- 调试信息 -->
<view wx:if="{{!artifacts || artifacts.length === 0}}" style="padding: 40rpx; text-align: center; color: #666;">
  <text>正在加载文物数据...</text>
  <!-- <view style="margin-top: 20rpx; font-size: 24rpx;">
    如果一直显示此信息，请检查：
    1. 云函数是否已部署
    2. 数据库集合是否创建
    3. 数据是否已导入
  </view> -->
</view>

<view class="content-section" wx:if="{{artifacts && artifacts.length > 0}}">
    <view class="content-grid">
      <view
        class="content-card"
        wx:for="{{artifacts}}"
        wx:key="id"
        bindtap="navigateToObject"
        data-page="{{item.page}}"
      >
        <image src="{{item.imageUrl}}" class="content-image" mode="aspectFill"></image>
        <view class="content-name">
          <text class="content-title">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>