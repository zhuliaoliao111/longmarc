.book-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #F5F5DC 0%, #DEB887 100%);
  padding: 20rpx;
  position: relative;
}

.book-cover {
  background: linear-gradient(45deg, #8B4513, #A0522D);
  color: #FFF8DC;
  padding: 40rpx;
  text-align: center;
  border-radius: 15rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.2);
}

.book-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.book-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
}

.book-content {
  background: #FFF8DC;
  border-radius: 15rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
  min-height: 600rpx;
  position: relative;
  transition: transform 0.3s ease;
}

.page-flip-in {
  animation: pageFlipIn 0.5s ease;
}

@keyframes pageFlipIn {
  0% { transform: rotateY(-90deg); opacity: 0; }
  100% { transform: rotateY(0deg); opacity: 1; }
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #DEB887;
}

.date {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
}

.voice-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.voice-btn.playing {
  background: #DC143C;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.voice-icon {
  font-size: 24rpx;
  color: white;
}

.page-content {
  flex: 1;
  line-height: 2;
}

.diary-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  text-indent: 2em;
}

.page-footer {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
}

.page-number {
  font-size: 20rpx;
  color: #8B4513;
  opacity: 0.7;
}

.book-controls {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.control-btn {
  flex: 1;
  height: 80rpx;
  background: #8B4513;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn:disabled {
  background: #CCC;
  color: #666;
}