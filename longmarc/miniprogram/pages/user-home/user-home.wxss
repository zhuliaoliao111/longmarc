/* pages/user-home/user-home.wxss */
.container {
  background-color: #faf8f5;
  height: 100vh; /* 固定高度，防止滚动 */
  overflow: hidden; /* 禁止滚动 */
  padding-bottom: 160rpx; /* 为底部固定按钮留出空间 */
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 内容区域 */
.content-area {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 背景图片 */
.page-bg-image {
  position: fixed;
  top: -170rpx;
  left: 0;
  width: 100%;
  height: 45%;
  z-index: 0;
  opacity: 0.7;
  object-fit: cover;
}

/* 背景图片渐变遮罩 */
.page-bg-image::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(to bottom, 
    rgba(250, 248, 245, 0) 0%,
    rgba(250, 248, 245, 0.2) 20%,
    rgba(250, 248, 245, 0.5) 50%,
    rgba(250, 248, 245, 0.8) 80%,
    rgba(250, 248, 245, 1) 100%
  );
  z-index: 1;
}

/* 用户信息区域 */
.user-info-section {
  position: relative;
  z-index: 1;
  padding: 40rpx 20rpx 20rpx 20rpx;
  background: transparent;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  padding: 20rpx;
  position: relative;
  z-index: 2;
}

.avatar-section {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  position: relative;
  margin-right: 30rpx;
  overflow: hidden;
  z-index: 2;
  border: 4rpx solid #8B0000; /* 深红色边框 */
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 56rpx;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.user-avatar::after {
  content: '👤';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 2;
}

/* 当头像加载失败或为空时，显示默认头像 */
.user-avatar[src=""],
.user-avatar:not([src]) {
  background: transparent;
}

.user-avatar[src=""]::after,
.user-avatar:not([src])::after {
  opacity: 1;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}



/* 统计数据区域 */
.stats-section {
  background: #faf8f5;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B0000;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: #e5e5e5;
}

/* 解锁章节区域 */
.chapters-section {
  background: #faf8f5;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.chapters-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 15rpx;
}

.chapter-item {
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  aspect-ratio: 1; /* 正方形 */
  min-height: 120rpx;
  max-height: 150rpx;
}

/* 移除冲突的旧样式，现在使用grayscale类来控制灰度效果 */

.chapter-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 8rpx;
  border-radius: 8rpx;
}

.chapter-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
  text-align: center;
  line-height: 1.2;
}

.chapter-status {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.chapter-status.unlocked {
  background: #e8f5e8;
  color: #2e7d32;
}

.chapter-item.locked .chapter-status {
  background: #ffebee;
  color: #c62828;
}

.chapter-content {
  position: relative;
  z-index: 1;
  padding: 10rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(250, 248, 245, 0.9);
  border-radius: 12rpx;
}

.chapter-content .chapter-status {
  margin-top: 4rpx;
}

.red-text {
  color: #8B0000 !important;
}

/* 灰度效果样式 - 微信小程序不支持filter，使用遮罩方案 */
.grayscale {
  opacity: 0.4;
  position: relative;
}

/* 为灰度图片添加半透明的灰色遮罩 */
.grayscale::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(128, 128, 128, 0.6);
  border-radius: inherit;
  pointer-events: none;
  z-index: 1;
}

.grayscale-text {
  color: #888 !important;
  opacity: 0.5;
  font-weight: normal !important;
}

/* 底部按钮区域 */
.bottom-buttons-section {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  background: #faf8f5;
  padding: 20rpx 40rpx 40rpx 40rpx;
  display: flex;
  gap: 20rpx;
  z-index: 10;
  box-shadow: none; /* 去掉阴影 */
}

.exercise-record-btn {
  flex: 1;
  background: #B8860B; /* 深黄色 */
  color: white;
  border: none !important;
  border-width: 0 !important;
  border-style: none !important;
  border-radius: 50rpx; /* 椭圆形 */
  padding: 24rpx 20rpx; /* 增加高度 */
  font-size: 28rpx; /* 稍微减小字体 */
  font-weight: bold;
  box-shadow: none !important; /* 去掉阴影 */
  transition: all 0.3s ease;
  outline: none !important; /* 去掉焦点边框 */
  -webkit-appearance: none; /* 去掉webkit默认样式 */
  appearance: none; /* 去掉默认样式 */
  line-height: 1; /* 防止文字偏移 */
}

.exercise-record-btn:active {
  background: #9A7209;
  transform: scale(0.98);
}

.exercise-record-btn::after {
  border: none !important; /* 去掉微信小程序button的默认边框 */
  display: none !important; /* 完全隐藏伪元素 */
}

.logout-btn {
  flex: 1;
  background: #8B0000; /* 深红色 */
  color: white;
  border: none !important;
  border-width: 0 !important;
  border-style: none !important;
  border-radius: 50rpx; /* 椭圆形 */
  padding: 24rpx 20rpx; /* 增加高度 */
  font-size: 28rpx; /* 稍微减小字体 */
  font-weight: bold;
  box-shadow: none !important; /* 去掉阴影 */
  transition: all 0.3s ease;
  outline: none !important; /* 去掉焦点边框 */
  -webkit-appearance: none; /* 去掉webkit默认样式 */
  appearance: none; /* 去掉默认样式 */
  line-height: 1; /* 防止文字偏移 */
}

.logout-btn:active {
  background: #660000;
  transform: scale(0.98);
}

.logout-btn::after {
  border: none !important; /* 去掉微信小程序button的默认边框 */
  display: none !important; /* 完全隐藏伪元素 */
}


/* 响应式调整 */
@media (max-width: 750rpx) {
  .chapters-grid {
    grid-template-columns: 1fr 1fr 1fr; /* 保持3列布局 */
    gap: 10rpx;
  }

  .chapter-item {
    min-height: 100rpx;
    max-height: 120rpx;
  }

  .chapter-icon {
    width: 48rpx;
    height: 48rpx;
  }

  .chapter-name {
    font-size: 20rpx;
  }

  .chapter-status {
    font-size: 16rpx;
  }

  .stats-section {
    flex-direction: column;
    gap: 20rpx;
  }

  .stat-divider {
    width: 60rpx;
    height: 2rpx;
    align-self: center;
  }

  .user-info-section {
    padding: 30rpx 20rpx 20rpx 20rpx;
  }

  .user-avatar {
    width: 100rpx;
    height: 100rpx;
  }
}
