<view class="container" catchtouchmove="preventMove">
  <view class="background-wrapper">
    <image class="background-image" src="{{backgroundImageUrl}}" mode="aspectFill"></image>
    <view class="gradient-mask"></view>
  </view>
  
  <view class="header">
    <view class="title-container">
      <image class="plum-bg" src="{{plumBgUrl}}" mode="aspectFit"></image>
      <text class="title">长征日记</text>
    </view>
    <text class="disclaimer">内容均选自《长征日记》作者：萧峰</text>
  </view>
  
  <view class="swiper-container">
    <swiper 
      class="diary-swiper" 
      indicator-dots="true"
      indicator-color="rgba(139,69,19,0.3)"
      indicator-active-color="#8B4513"
      circular="true"
      autoplay="false"
      current="{{current}}"
      bindchange="onSwiperChange"
      previous-margin="160rpx"
      next-margin="160rpx"
      skip-hidden-item-layout="false"
    >
      <swiper-item 
        wx:for="{{books}}" 
        wx:key="id"
      >
        <view class="diary-card {{current === index ? 'active' : ''}}" bindtap="openBook" data-id="{{item.id}}">
          <image class="card-image" src="{{item.cover}}" mode="aspectFill"></image>
        </view>
      </swiper-item>
    </swiper>
  </view>
</view>