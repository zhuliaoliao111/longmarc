<view class="container">
  <!-- 轨迹记录模式切换 -->
  <view class="mode-tabs">
    <view class="tab-item {{currentMode === 'record' ? 'active' : ''}}" bindtap="switchMode" data-mode="record">
      户外锻炼
    </view>
    <view class="tab-item {{currentMode === 'history' ? 'active' : ''}}" bindtap="switchMode" data-mode="history">
      运动记录
    </view>
  </view>

  <!-- 记录轨迹模式 -->
  <view wx:if="{{currentMode === 'record'}}" class="record-mode">
    <!-- 使用腾讯地图组件（微信小程序内置） -->
    <!-- 高德地图SDK用于地理编码等API服务 -->
    <map
      class="map-container"
      polyline="{{polyline}}"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      show-location="true"
    ></map>

    <!-- 距离显示区域 -->
    <view class="distance-section">
      <text class="distance-number">{{distance.toFixed ? distance.toFixed(2) : distance}}</text>
      <text class="distance-unit">km</text>
    </view>

    <!-- 运动效率详细说明 -->
    <view class="efficiency-detail-tip" wx:if="{{showEfficiencyTip}}" bindtap="hideEfficiencyTip">
      <view class="detail-header">
        <text class="detail-title">🏃‍♂️ 前进效率对比</text>
        <text class="close-hint">点击关闭</text>
      </view>
      <view class="detail-items">
        <view class="detail-item">
          <view class="detail-icon">🚶‍♂️</view>
          <view class="detail-content">
            <text class="detail-label">微信步数</text>
            <text class="detail-desc">×20倍权重</text>
          </view>
        </view>
        <view class="detail-item highlight">
          <view class="detail-icon">🏃‍♂️</view>
          <view class="detail-content">
            <text class="detail-label">户外锻炼</text>
            <text class="detail-desc">×40倍权重</text>
          </view>
          <view class="efficiency-badge">高效</view>
        </view>
      </view>
      <view class="detail-footer">
        <text class="detail-tip">💡 使用小程序进行户外锻炼，前进效率更高哦</text>
      </view>
    </view>


    <!-- 透明统计框 -->
    <view class="stats-container">
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-number">{{time}}</text>
          <text class="stat-label">跑步时长</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{speed.toFixed ? speed.toFixed(2) : speed}}</text>
          <text class="stat-label">平均配速</text>
        </view>
      </view>
      
      <!-- 控制按钮放在透明框内 -->
      <view class="controls">
        <button wx:if="{{!isTracking}}" class="control-btn start-btn" bindtap="startTracking">开始运动</button>
        <button wx:if="{{isTracking && !isPaused}}" class="control-btn pause-btn" bindtap="pauseTracking">暂停</button>
        <button wx:if="{{isPaused}}" class="control-btn start-btn" bindtap="startTracking">开始</button>
        <button wx:if="{{isTracking}}" class="control-btn end-btn" bindtap="stopTracking">结束</button>
      </view>
    </view>
  </view>

  <!-- 历史轨迹记录模式 -->
  <view wx:elif="{{currentMode === 'history'}}">
    <view wx:if="{{trajectoryList.length > 0}}">
      <!-- 运动总距离统计 -->
      <view class="total-exercise-section">
        <view class="exercise-content">
          <view class="total-exercise-title">运动总距离</view>
          <view class="total-exercise-value">
            <text class="distance-number">{{totalExerciseDistance}}</text>
            <text class="distance-unit">km</text>
          </view>
        </view>
      </view>

      <view class="history-section">
        <view class="section-title">运动轨迹记录</view>

        <scroll-view class="trajectory-list" scroll-y="true" enable-flex="true" scroll-with-animation="{{true}}" enable-back-to-top="{{true}}" refresher-enabled="{{true}}" refresher-triggered="{{refresherTriggered}}" bindrefresherrefresh="onRefresh" bindrefresherrestore="onRefreshRestore">
          <view class="trajectory-card" wx:for="{{trajectoryList}}" wx:key="id">
            <image class="trajectory-bg-image" src="{{trajectoryBgUrl}}" mode="aspectFill"></image>
            <view class="trajectory-overlay"></view>
            <view class="trajectory-info">
              <view class="trajectory-date">{{item.createdAt.toLocaleDateString()}} {{item.createdAt.toLocaleTimeString()}}</view>
              <view class="trajectory-stats">
                <text class="stat">距离: {{item.distance}} km</text>
                <text class="stat">时间: {{item.time}}</text>
              </view>
            </view>
            <view class="trajectory-canvas-container">
              <!-- Canvas轨迹绘制 - 总是渲染，但只在有数据时绘制 -->
              <canvas
                class="trajectory-canvas"
                id="canvas_{{index}}"
                canvas-id="canvas_{{index}}"
                data-item-id="{{item._id}}"
                data-index="{{index}}"
                data-has-data="{{item.points && item.points.length > 0}}"
                bindready="onCanvasReady"
                binderror="onCanvasError"
                disable-scroll="{{true}}"
              ></canvas>

              <!-- 无轨迹数据提示 -->
              <view wx:if="{{!item.points || item.points.length === 0}}" class="trajectory-placeholder">
                <text class="placeholder-text">无轨迹数据</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view wx:else class="empty-section">
      <view class="empty-content">
        <view class="empty-text">暂无轨迹记录</view>
        <view class="empty-subtext">开始记录您的运动轨迹吧！</view>
        <button class="start-record-btn" bindtap="switchMode" data-mode="record">开始记录</button>
      </view>
    </view>
  </view>

  <canvas
    canvas-id="trajectoryCanvas"
    style="width: 400px; height: 600px; position: absolute; left: -9999px; top: -9999px;"
    disable-scroll="true"
  ></canvas>
</view>
