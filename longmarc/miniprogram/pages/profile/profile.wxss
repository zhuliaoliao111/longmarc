/* pages/profile/profile.wxss */
.container {
  padding: 32rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.user-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  margin-right: 24rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #e9ecef;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 24rpx;
  color: #6c757d;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 8rpx;
}

.location {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
  margin-top: 4rpx;
}

.login-btn {
  background: #dc3545;
  color: white;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  width: 100%;
}

/* 数据统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #dc3545;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
}

/* 进度卡片 */
.progress-card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212529;
}

.progress-text {
  font-size: 24rpx;
  color: #6c757d;
}

.progress-bar {
  height: 8rpx;
  background: #e9ecef;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #dc3545;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
}

.action-btn.primary {
  background: #dc3545;
  color: white;
}

.action-btn.secondary {
  background: #6c757d;
  color: white;
}

.action-btn:active {
  opacity: 0.8;
}

/* 用户操作按钮区域 */
.user-actions {
  margin-top: 16rpx;
}

.logout-btn {
  background: #6c757d;
  color: white;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border: none;
}

/* 退出登录区域（页面底部） */
.logout-section {
  margin-top: 40rpx;
  padding: 0 32rpx 40rpx;
}

.logout-btn-bottom {
  width: 100%;
  background: #dc3545;
  color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(220, 53, 69, 0.3);
}

.logout-btn-bottom:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 调整用户信息卡片样式，移除原来的退出按钮样式 */
.user-actions {
  margin-top: 16rpx;
}

.login-btn {
  background: #dc3545;
  color: white;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  width: 100%;
}

/* 移除原来的logout-btn样式，因为现在使用logout-btn-bottom */
/* .logout-btn 样式已移除 */

/* 按钮点击效果 */
.login-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 头像容器样式 */
.avatar-container {
  position: relative;
  display: inline-block;
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #e9ecef;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 24rpx;
  color: #6c757d;
}

/* 头像编辑提示 */
.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  background: #dc3545;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid white;
}

.edit-icon {
  font-size: 12rpx;
}

/* 头像上传状态 */
.upload-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-text {
  color: white;
  font-size: 20rpx;
}

/* 昵称容器样式 */
.nickname-container {
  display: flex;
  align-items: center;
  padding: 8rpx;
  border-radius: 8rpx;
  transition: background-color 0.2s;
}

.nickname-container:active {
  background-color: #f8f9fa;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
}

.edit-hint {
  margin-left: 8rpx;
  font-size: 20rpx;
  opacity: 0.6;
}

.location {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
  margin-top: 4rpx;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 500rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  text-align: center;
}

.modal-body {
  padding: 24rpx;
}

.nickname-input {
  width: 100%;
  padding: 16rpx;
  border: 2rpx solid #e9ecef;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #f8f9fa;
}

.nickname-input:focus {
  border-color: #dc3545;
}

.input-counter {
  text-align: right;
  font-size: 24rpx;
  color: #6c757d;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
  background: white;
}

.cancel-btn {
  color: #6c757d;
  border-right: 1rpx solid #eee;
}

.confirm-btn {
  color: #dc3545;
  font-weight: 600;
}

.modal-btn:active {
  background: #f8f9fa;
}

/* 认证按钮区域（页面底部） */
.auth-section {
  margin-top: 40rpx;
  padding: 0 32rpx 40rpx;
}

.auth-btn {
  width: 100%;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.login-btn {
  background: #07c160;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.logout-btn {
  background: #dc3545;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(220, 53, 69, 0.3);
}

.auth-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
