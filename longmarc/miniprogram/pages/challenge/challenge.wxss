/* 主容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fcf3eb 0%, #edd4ba 100%);
  position: relative;
}

/* 卡片容器 */
.cards-container {
  padding: 20px 10px;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

/* 卡片包装器 */
.card-wrapper {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* 功能卡片 */
.feature-card {
  position: relative;
  height: 200px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  cursor: pointer;
}

.feature-card:active {
  transform: scale(0.98);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

/* 卡片背景 */
.card-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

.card-bg-image {
  width: 100%;
  height: 100%;
  transition: opacity 0.3s ease;
  background: linear-gradient(135deg, #f5f1eb 0%, #e8dcc6 100%);
}

.card-bg-image[data-loaded="false"] {
  opacity: 0.7;
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.1) 100%);
  z-index: 2;
}

/* 卡片标题区域 */
.card-title-section {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

/* 左侧金色竖条 */
.title-bar {
  width: 4px;
  height: 24px;
  background:rgb(147, 13, 13);
  border-radius: 2px;
  flex-shrink: 0;
}

/* 中文标题 */
.card-title {
  font-size: 20px;
  font-weight: bold;
  color: #8b4513;
  font-family: serif;
  flex-shrink: 0;
}

/* 英文标题 */
.title-english {
  font-size: 14px;
  font-weight: normal;
  color:rgb(230, 145, 66);
  font-family: serif;
  flex-shrink: 0;
}

/* 卡片内容 */
.card-content {
  position: absolute;
  bottom: 20px;
  left: 20px;
  z-index: 3;
}

.enter-text {
  color: white;
  font-size: 16px;
  font-weight: 500;
  text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
  z-index: 4;
}

/* 品牌标识 */
.card-brand {
  position: absolute;
  bottom: 20px;
  right: 20px;
  z-index: 4;
}

.brand-text {
  font-size: 12px;
  color: white;
  background: rgba(255, 255, 255, 0.2);
  padding: 4px 8px;
  border-radius: 8px;
  backdrop-filter: blur(10px);
}