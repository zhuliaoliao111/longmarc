<view class="container">
  <!-- 功能卡片区域 -->
  <view class="cards-container">
    <!-- 以笔绘长征卡片 -->
    <view class="card-wrapper">
      <view class="card-title-section">
        <view class="title-bar"></view>
        <text class="card-title">以"笔"绘长征</text>
      </view>
      <view class="feature-card" bindtap="navigateToAIImage">
        <view class="card-background">
        <image 
          class="card-bg-image" 
          src="{{cardImages.brush}}" 
          mode="aspectFill"
          lazy-load="{{true}}"
          bindload="onImageLoad"
          data-type="brush"
          binderror="onImageError"
          show-menu-by-longpress="{{false}}"
        ></image>
          <view class="card-overlay"></view>
        </view>
        <view class="card-content">
          <text class="enter-text">立即开始</text>
        </view>
      </view>
    </view>

    <!-- 以字忆长征卡片 -->
    <view class="card-wrapper">
      <view class="card-title-section">
        <view class="title-bar"></view>
        <text class="card-title">以"字"忆长征</text>
      </view>
      <view class="feature-card" bindtap="navigateToAIText">
        <view class="card-background">
        <image 
          class="card-bg-image" 
          src="{{cardImages.text}}" 
          mode="aspectFill"
          lazy-load="{{true}}"
          bindload="onImageLoad"
          data-type="text"
          binderror="onImageError"
          show-menu-by-longpress="{{false}}"
        ></image>
          <view class="card-overlay"></view>
        </view>
        <view class="card-content">
          <text class="enter-text">立即开始</text>
        </view>
      </view>
    </view>

    <!-- 以心看长征卡片 -->
    <view class="card-wrapper">
      <view class="card-title-section">
        <view class="title-bar"></view>
        <text class="card-title">以"心"看长征</text>
      </view>
      <view class="feature-card" bindtap="navigateToPoetryCards">
        <view class="card-background">
        <image 
          class="card-bg-image" 
          src="{{cardImages.heart}}" 
          mode="aspectFill"
          lazy-load="{{true}}"
          bindload="onImageLoad"
          data-type="heart"
          binderror="onImageError"
          show-menu-by-longpress="{{false}}"
        ></image>
          <view class="card-overlay"></view>
        </view>
        <view class="card-content">
          <text class="enter-text">立即开始</text>
        </view>        
      </view>
    </view>
  </view>
</view>