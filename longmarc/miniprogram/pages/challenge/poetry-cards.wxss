/* 主容器 */
.container {
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
  overflow-y: auto;
}

/* 背景装饰 */
.background-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 主标题区域 */
.main-title-section {
  padding: 80px 20px 30px;
  text-align: center;
  position: relative;
  z-index: 10;
}

.main-title {
  font-size: 26px;
  font-weight: bold;
  color: #764F35;
  margin-bottom: 10px;
  line-height: 1.4;
}

.main-subtitle {
  font-size: 20px;
  color: #99806C;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 60px;
  left: 15px;
  width: 44px;
  height: 44px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10px);
}

.back-icon {
  font-size: 24px;
  color: #333;
  font-weight: bold;
  margin-left: -2px;
}

/* 画廊容器 */
.gallery-container {
  padding: 30px 10px 80px;
  background: transparent;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* 诗词卡片 */
.poetry-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  cursor: pointer;
  transition: transform 0.3s ease;
  padding: 15px 0;
  gap: 15px;
  justify-content: flex-start;
}

.poetry-card:active {
  transform: scale(0.98);
}

/* 左侧卡片 */
.card-left {
  justify-content: flex-start;
  padding-left: 0px;
  padding-right: 10px;
}

/* 右侧卡片 */
.card-right {
  justify-content: flex-end;
  flex-direction: row-reverse;
  padding-left: 10px;
  padding-right: 0px;
}

/* 卡片图片 */
.card-image {
  width: 200px;
  height: 260px;
  object-fit: cover;
  flex-shrink: 0;
  max-width: 45%;
}

/* 卡片标题 */
.card-title {
  font-size: 16px;
  color: #333333;
  font-weight: 600;
  text-align: left;
  line-height: 1.4;
  white-space: pre-line;
  width: 180px;
  flex-shrink: 0;
  max-width: 50%;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗内容 */
.modal-content {
  background: #f1e6d5;
  border-radius: 16px;
  width: 95%;
  max-width: 450px;
  height: 80%;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

/* 弹窗头部 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 10px;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  white-space: pre-line;
}

.close-btn {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #ebe7e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #666;
  cursor: pointer;
}

.close-btn:active {
  background: #e0e0e0;
}

/* 弹窗主体 */
.modal-body {
  padding: 15px;
  text-align: center;
  flex: 1;
  overflow: hidden;
  box-sizing: border-box;
}

/* 弹窗图片 */
.modal-image {
  width: 100%;
  max-height: 400px;
  border-radius: 8px;
  margin-bottom: 20px;
}

/* 注释区域 */
.modal-annotation {
  text-align: left;
  line-height: 1.6;
  padding: 0 10px;
  box-sizing: border-box;
}

/* 注释部分 */
.annotation-section {
  margin-bottom: 15px;
  width: 100%;
  box-sizing: border-box;
}

.annotation-title {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  padding-bottom: 5px;
  border-bottom: 2px solid #e5e2e2;
  width: 100%;
  box-sizing: border-box;
}

.annotation-text {
  display: block;
  font-size: 17px;
  color: #524f4f;
  line-height: 1.6;
  margin-bottom: 10px;
  word-wrap: break-word;
  word-break: break-all;
  width: 100%;
  box-sizing: border-box;
}