/* 重置全局样式，确保无间距 */
.container {
  height: 100vh;
  overflow: hidden;
  background-color: #f8f9fa;
  position: relative;
  padding: 0 !important; /* 重置全局padding */
  margin: 0 !important; /* 确保无margin */
}

/* 背景图片区域 - 延伸到导航栏下方 */
.header-background {
  width: 100%;
  height: 650rpx;
  position: relative;
  overflow: hidden;
  margin-top: -88rpx; /* 负边距，向上移动到导航栏位置 */
  padding-top: 88rpx; /* 给导航栏预留空间 */
}

.background-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* 国风复古卡片内容区域 */
.content-card {
  background-color: #FDFBF6; /* 温暖的米白色，国风复古感 */
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -250rpx;
  padding: 60rpx 40rpx 40rpx;
  height: calc(100vh - 400rpx);
  overflow-y: auto;
  box-shadow: 0 -8rpx 32rpx rgba(139, 124, 99, 0.15); /* 使用暖色调的阴影 */
  position: relative;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx; /* 添加缺失的分号 */
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

/* 头像设置区域 */
.avatar-section {
  background-color: #F8F7F2; /* 稍微深一点的米色调 */
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 60rpx;
  margin: 0 auto 20rpx;
  background-color: #fff;
  border: 2rpx solid #E5DCC8; /* 温暖的边框色 */
  box-shadow: 0 4rpx 12rpx rgba(139, 124, 99, 0.1); /* 暖色调阴影 */
}

.avatar {
  display: block;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.avatar-desc {
  font-size: 24rpx;
  color: #999;
}

/* 昵称设置区域 */
.nickname-section {
  background-color: #F8F7F2; /* 与头像区域相同的米色调 */
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  text-align: center; /* 添加居中对齐 */
}

.row {
  border: 1rpx solid #E5DCC8; /* 温暖的边框色 */
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  height: 100rpx;
  padding: 0 20rpx;
  background-color: #fff;
  justify-content: center; /* 添加水平居中对齐 */
}

.text1 {
  flex: none; /* 移除自适应宽度 */
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx; /* 添加右边距 */
}

.weui-input {
  flex: none; /* 移除自适应宽度 */
  font-size: 28rpx;
  color: #333;
  border: none;
  text-align: center; /* 输入框文字也居中 */
  width: 300rpx; /* 固定宽度 */
}

/* 按钮区域 */
.button-section {
  display: flex;
  flex-direction: row; /* 从column改为row，水平排列 */
  gap: 20rpx;
  margin-top: 300rpx; /* 从40rpx增加到80rpx，让按钮往下移动 */
  justify-content: center; /* 水平居中对齐 */
}

.submit-btn {
  background-color: #8B4513; /* 深棕色，与图片中签到积分按钮颜色一致 */
  color: white;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3); /* 深棕色阴影 */
  flex: 1; /* 让一个按钮占据一半宽度 */
  max-width: 300rpx; /* 限制最大宽度 */
}

.skip-btn {
  background-color: #F8F7F2; /* 温暖的米色调 */
  color: #8B7428; /* 温暖的棕色文字 */
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  border: 1rpx solid #E5DCC8; /* 温暖边框色 */
  flex: 1; /* 让一个按钮占据一半宽度 */
  max-width: 300rpx; /* 限制最大宽度 */
}
