.title { font-size: 20px; font-weight: 700; }
.meta { color: #666; margin-top: 6px; font-size: 12px; }
.banner { width: 100%; height: 160px; border-radius: 6px; margin: 12px 0; }
.content { line-height: 1.7; margin: 10px 0; }
.gallery { white-space: nowrap; margin-top: 8px; }
.thumb { width: 120px; height: 80px; border-radius: 6px; margin-right: 8px; display: inline-block; }
.ml8 { margin-left: 8px; }

/* 结果提示样式 */
.result {
  padding: 15px;
  margin-bottom: 20px;
  border-radius: 8px;
  line-height: 1.7;
  font-size: 16px;
  background-color: transparent;
  border-left: 4px solid #ff0000;
} 