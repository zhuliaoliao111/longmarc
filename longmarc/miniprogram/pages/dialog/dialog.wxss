.container {
  position: relative;
  padding: 20rpx;
  background: linear-gradient(135deg, #f1f1f1 0%, #ffffff 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: rgb(26, 24, 24);
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-top: 20rpx;
  margin-bottom: 30rpx;  /* 增加下边距，空一行 */
}

.description {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  font-style: italic;
}

.heroes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.hero-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.hero-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.hero-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 30rpx;
  border: 4rpx solid #7a0000;
}

.hero-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.hero-title {
  display: block;
  font-size: 28rpx;  /* 从 24rpx 增大到 28rpx，与 hero-desc 保持一致 */
  color: #000;  /* 从 #666 改为黑色，更突出 */
  margin-bottom: 6rpx;
}

.hero-desc {
  display: block;
  font-size: 28rpx;  /* 从 20rpx 增大到 28rpx */
  color: #000;  /* 从 #888 改为黑色 */
  margin-top: 6rpx;
}

.tips {
  margin-top: 60rpx;
  margin-bottom: 100rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.tips-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #7a0000;
  margin-bottom: 20rpx;
}

.tips-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.background-image {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50vh;
  z-index: 0;
  overflow: hidden;
}

.bg-img {
  width: 100%;
  height: 100%;
  opacity: 0.9;
  mask: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.3) 70%, rgba(0,0,0,0) 100%);
  -webkit-mask: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.3) 70%, rgba(0,0,0,0) 100%);
  object-fit: cover;
}

.ending-section {
  text-align: center;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}