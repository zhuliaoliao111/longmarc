.container {
  position: relative;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom); /* 适配底部安全区域 */
  padding-left: 0; /* 确保容器左边没有内边距 */
  margin: 0; /* 确保容器没有外边距 */
}



.chat-container {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%;
  align-items: stretch;
  justify-content: flex-start;
  padding-left: 0; /* 确保聊天容器左边没有内边距 */
  margin: 0; /* 确保聊天容器没有外边距 */
}

.messages-container {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 40rpx; /* 大幅增加左边距，确保头像完全显示 */
  background: transparent;
  width: 100%;
  box-sizing: border-box;
}

.messages-container.no-scroll {
  overflow-y: hidden; /* 不能滚动时隐藏滚动条 */
}

.messages-container.scrollable {
  overflow-y: auto; /* 可以滚动时显示滚动条 */
}

.message-item {
  margin-bottom: 30rpx;
}

.message-content {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.hero-message {
  justify-content: flex-start;
}

.user-message {
  justify-content: flex-end;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 3rpx solid #d81e06;
  flex-shrink: 0;
  margin: 0; /* 确保头像没有额外的外边距 */
}

.hero-message .avatar {
  margin-right: 20rpx;
  margin-left: 0; /* 确保头像左边没有额外边距 */
}

.user-message .avatar {
  margin-left: 20rpx;
}

.message-bubble {
  max-width: 500rpx;
  padding: 20rpx 25rpx;
  border-radius: 20rpx;
  position: relative;
}

.hero-bubble {
  background: #f0f0f0;
  border-top-left-radius: 8rpx;
}

.user-bubble {
  background: #d81e06;
  border-top-right-radius: 8rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  word-wrap: break-word;
}

.hero-bubble .message-text {
  color: #333;
}

.user-bubble .message-text {
  color: #fff;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.hero-bubble .message-time {
  text-align: right;
}

.user-bubble .message-time {
  text-align: left;
  color: rgba(255, 255, 255, 0.8);
}

.loading-message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.loading-message .avatar {
  margin-right: 20rpx;
  margin-left: 0; /* 确保加载消息的头像左边没有额外边距 */
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  font-style: italic;
}

.input-container {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5; /* 与页面背景色一致 */
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
  position: fixed; /* 改为固定定位 */
  bottom: 0; /* 固定在底部 */
  left: 0;
  right: 0;
  z-index: 10; /* 确保在最上层 */
}

.message-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #fff; /* 输入框本身保持白色背景 */
  margin-right: 20rpx;
  box-sizing: border-box;
}

.message-input:focus {
  border-color: #d81e06;
  background: #fff;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: #d81e06;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn:disabled {
  background: #ccc;
  color: #999;
}

.send-btn:active {
  background: #b71c1c;
}
.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-story {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 12rpx;
  text-align: left;
}